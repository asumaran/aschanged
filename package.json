{
  "name": "aschanged",
  "displayName": "AS Changed",
  "description": "Muestra en el Explorer los archivos modificados en el branch actual respecto a su branch base, diferenciando cambios commiteados de cambios pendientes.",
  "version": "0.1.0",
  "publisher": "asumaran",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/asumaran/aschanged.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:aschanged.view"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "aschanged.view",
          "name": "Branch Changes",
          "icon": "$(git-branch)",
          "contextualTitle": "Branch Changes"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "aschanged.view",
        "contents": "No hay archivos modificados respecto a la base.\n[Recargar](command:aschanged.refresh)"
      }
    ],
    "commands": [
      {
        "command": "aschanged.refresh",
        "title": "Refrescar",
        "category": "Branch Changes",
        "icon": "$(refresh)"
      },
      {
        "command": "aschanged.setBase",
        "title": "Elegir branch base...",
        "category": "Branch Changes",
        "icon": "$(git-compare)"
      },
      {
        "command": "aschanged.autoDetectBase",
        "title": "Auto-detectar branch base (merge-base más cercano)",
        "category": "Branch Changes",
        "icon": "$(wand)"
      },
      {
        "command": "aschanged.clearBase",
        "title": "Restablecer base al default",
        "category": "Branch Changes",
        "icon": "$(discard)"
      },
      {
        "command": "aschanged.openDiff",
        "title": "Abrir diff contra la base",
        "category": "Branch Changes",
        "icon": "$(git-compare)"
      },
      {
        "command": "aschanged.viewAsTree",
        "title": "Ver como árbol de carpetas",
        "category": "Branch Changes",
        "icon": "$(list-tree)"
      },
      {
        "command": "aschanged.viewAsList",
        "title": "Ver como lista plana",
        "category": "Branch Changes",
        "icon": "$(list-flat)"
      },
      {
        "command": "aschanged.fetchBase",
        "title": "Fetch del branch base (actualizar origin)",
        "category": "Branch Changes",
        "icon": "$(cloud-download)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "aschanged.refresh",
          "when": "view == aschanged.view",
          "group": "navigation@1"
        },
        {
          "command": "aschanged.fetchBase",
          "when": "view == aschanged.view",
          "group": "1_base@0"
        },
        {
          "command": "aschanged.viewAsTree",
          "when": "view == aschanged.view && aschanged.viewMode == list",
          "group": "navigation@0"
        },
        {
          "command": "aschanged.viewAsList",
          "when": "view == aschanged.view && aschanged.viewMode == tree",
          "group": "navigation@0"
        },
        {
          "command": "aschanged.setBase",
          "when": "view == aschanged.view",
          "group": "navigation@2"
        },
        {
          "command": "aschanged.autoDetectBase",
          "when": "view == aschanged.view",
          "group": "1_base@1"
        },
        {
          "command": "aschanged.clearBase",
          "when": "view == aschanged.view",
          "group": "1_base@2"
        }
      ],
      "view/item/context": [
        {
          "command": "aschanged.openDiff",
          "when": "view == aschanged.view && viewItem == changedFile",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "AS Changed",
      "properties": {
        "aschanged.alwaysCompareToMain": {
          "type": "boolean",
          "default": false,
          "description": "Forzar siempre la comparación contra el branch principal, ignorando overrides manuales por branch."
        },
        "aschanged.mainBranchCandidates": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "main",
            "master",
            "develop"
          ],
          "description": "Branches candidatos a usarse como base por defecto, en orden de prioridad."
        },
        "aschanged.respectFilesExclude": {
          "type": "boolean",
          "default": true,
          "description": "Ocultar archivos que coincidan con los globs de la configuración 'files.exclude' (igual que el Explorer)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "minimatch": "^9.0.5"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0"
  }
}
