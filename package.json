{
  "name": "aschanged",
  "displayName": "AS Changed",
  "description": "Shows the files changed in the current branch relative to its base branch in the Explorer, distinguishing committed from pending changes.",
  "version": "0.1.0",
  "publisher": "asumaran",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/asumaran/aschanged.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:aschanged.view"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "aschanged.view",
          "name": "Branch Changes",
          "icon": "$(git-branch)",
          "contextualTitle": "Branch Changes"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "aschanged.view",
        "contents": "No files changed relative to the base.\n[Reload](command:aschanged.refresh)"
      }
    ],
    "commands": [
      {
        "command": "aschanged.refresh",
        "title": "Refresh",
        "category": "Branch Changes",
        "icon": "$(refresh)"
      },
      {
        "command": "aschanged.setBase",
        "title": "Pick base branch...",
        "category": "Branch Changes",
        "icon": "$(git-compare)"
      },
      {
        "command": "aschanged.autoDetectBase",
        "title": "Auto-detect base branch (closest merge-base)",
        "category": "Branch Changes",
        "icon": "$(wand)"
      },
      {
        "command": "aschanged.clearBase",
        "title": "Reset base to default",
        "category": "Branch Changes",
        "icon": "$(discard)"
      },
      {
        "command": "aschanged.openDiff",
        "title": "Open diff against the base",
        "category": "Branch Changes",
        "icon": "$(git-compare)"
      },
      {
        "command": "aschanged.viewAsTree",
        "title": "View as folder tree",
        "category": "Branch Changes",
        "icon": "$(list-tree)"
      },
      {
        "command": "aschanged.viewAsList",
        "title": "View as flat list",
        "category": "Branch Changes",
        "icon": "$(list-flat)"
      },
      {
        "command": "aschanged.fetchBase",
        "title": "Fetch base branch (update origin)",
        "category": "Branch Changes",
        "icon": "$(cloud-download)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "aschanged.refresh",
          "when": "view == aschanged.view",
          "group": "navigation@1"
        },
        {
          "command": "aschanged.fetchBase",
          "when": "view == aschanged.view",
          "group": "1_base@0"
        },
        {
          "command": "aschanged.viewAsTree",
          "when": "view == aschanged.view && aschanged.viewMode == list",
          "group": "navigation@0"
        },
        {
          "command": "aschanged.viewAsList",
          "when": "view == aschanged.view && aschanged.viewMode == tree",
          "group": "navigation@0"
        },
        {
          "command": "aschanged.setBase",
          "when": "view == aschanged.view",
          "group": "navigation@2"
        },
        {
          "command": "aschanged.autoDetectBase",
          "when": "view == aschanged.view",
          "group": "1_base@1"
        },
        {
          "command": "aschanged.clearBase",
          "when": "view == aschanged.view",
          "group": "1_base@2"
        }
      ],
      "view/item/context": [
        {
          "command": "aschanged.openDiff",
          "when": "view == aschanged.view && viewItem == changedFile",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "AS Changed",
      "properties": {
        "aschanged.alwaysCompareToMain": {
          "type": "boolean",
          "default": false,
          "description": "Always force the comparison against the main branch, ignoring per-branch manual overrides."
        },
        "aschanged.mainBranchCandidates": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "main",
            "master",
            "develop"
          ],
          "description": "Candidate branches to use as the default base, in priority order."
        },
        "aschanged.respectFilesExclude": {
          "type": "boolean",
          "default": true,
          "description": "Hide files matching the 'files.exclude' globs (just like the Explorer)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "minimatch": "^9.0.5"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0"
  }
}
